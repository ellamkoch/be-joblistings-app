    {
      "name": "Auth - Register",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "pm.test('Envelope has token', function () {",
              "    pm.expect(json).to.have.property('data');",
              "    pm.expect(json.data).to.be.an('object');",
              "    pm.expect(json.data).to.have.property('token');",
              "});",
              "",
              "if (json.data && json.data.token) {",
              "    pm.collectionVariables.set('token', json.data.token);",
              "}",
              "",
              "if (json.data && json.data.user && json.data.user.id !== undefined) {",
              "    pm.collectionVariables.set('userId', String(json.data.user.id));",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
